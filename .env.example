# ===== プラットフォーム（あなた）の Stripe 設定 =====
# プラットフォームの秘密鍵。Connect 経由で各主催者の決済を作成する際に使用。
# まずはテスト用キー（sk_test_ で始まる文字列）で動作確認してください。
STRIPE_SECRET_KEY=

# Stripe Connect の client_id（ダッシュボード > Connect > 設定）。例: ca_xxx
# 主催者を OAuth で連携させる際に必要。
STRIPE_CONNECT_CLIENT_ID=

# Webhook の署名シークレット（任意）。
STRIPE_WEBHOOK_SECRET=

# このアプリの公開URL。Connect の戻りURL・success/cancel のリンク生成に使用。
APP_BASE_URL=http://localhost:8000

# SQLite ファイルの場所（任意・既定は data/app.sqlite）
# DB_PATH=/var/data/app.sqlite

# 送信メールの差出人（パスワード再設定・申込確認メールに使用）
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=イベント事前決済

# ===== プラン課金（主催者→運営者）の Stripe Price ID =====
# プラットフォーム本体の Stripe で「商品＋価格（月額サブスク）」を作成し、その price_... を設定。
# 未設定のプランはアップグレード画面に表示されません。
#   月5イベント = ¥500 / 月10イベント = ¥1,000 / 無制限 = ¥1,500
STRIPE_PRICE_P5=
STRIPE_PRICE_P10=
STRIPE_PRICE_UNLIMITED=
