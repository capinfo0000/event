# Stripe の秘密鍵（ダッシュボード > 開発者 > APIキー）。
# まずはテスト用キー（sk_test_ で始まる文字列）で動作確認してください。
# 例: STRIPE_SECRET_KEY=sk_test_あなたの実際のキー
STRIPE_SECRET_KEY=

# Webhook の署名シークレット（任意）。
# ローカルでは `stripe listen` 実行時に表示される whsec_ で始まる値を設定。
STRIPE_WEBHOOK_SECRET=

# このアプリの公開URL。success/cancel/webhook のリンク生成に使用。
# ローカル開発ではこのままでOK。
APP_BASE_URL=http://localhost:8000

# 参加者管理画面（/admin/）のログイン情報（ID＋パスワード）。
# 個人情報を表示する画面なので、必ず推測されにくい値に変更してください。
ADMIN_USER=admin
ADMIN_PASS=
