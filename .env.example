# ===== あなた（運営者）の Stripe 設定 =====
# あなた自身の Stripe シークレットキー。参加費はこのアカウントへ直接入金されます。
# まずはテスト用キー（sk_test_ で始まる文字列）で動作確認してください。
# 本番は sk_live_ のキーに差し替えます。
STRIPE_SECRET_KEY=

# Webhook の署名シークレット（任意。現状の決済フローでは未使用でも動作します）。
STRIPE_WEBHOOK_SECRET=

# Stripe Connect の client_id（ca_... 形式）。設定すると主催者が各自の Stripe を接続でき、
# 参加費の入金・名簿(PII)・決済データが主催者ごとに物理分離されます（推奨）。
# 未設定なら従来どおりプラットフォームの STRIPE_SECRET_KEY を直接使用します（後方互換）。
# 取得: Stripe ダッシュボード → Connect → 設定 → OAuth の client_id
STRIPE_CONNECT_CLIENT_ID=

# このアプリの公開URL。決済完了/中断（success/cancel）のリンク生成に使用。
APP_BASE_URL=http://localhost:8000

# SQLite ファイルの場所（任意・既定は data/app.sqlite）
# DB_PATH=/var/data/app.sqlite

# 送信メールの差出人（パスワード再設定・申込確認メールに使用）
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=イベント事前決済

# 新規登録（オープン登録）の受付可否。単独運営に切り替えるなら 0 で閉じられる（既定: 1=受付）。
ALLOW_SIGNUP=1

# メールログ(logs/mail.log)のローテーション上限バイト数（既定 5MB）。0 以下で無効。
# MAIL_LOG_MAX_BYTES=5242880

# CAPTCHA（Cloudflare Turnstile）。両方設定すると signup/forgot/申込フォームでボット対策が有効化。
# 未設定なら無効（素通り）。https://dash.cloudflare.com/?to=/:account/turnstile で取得。
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
